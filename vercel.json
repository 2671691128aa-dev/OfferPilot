{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://offerpilot-production-010e.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}